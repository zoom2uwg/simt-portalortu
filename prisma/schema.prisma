// =====================================================
// SIMT MTs - Sistem Informasi Manajemen Terpadu
// Madrasah Tsanawiyah / SMP Yayasan
// Multi-Tenant Database Schema
//
// DATABASE PROVIDER OPTIONS (set in .env):
//   PostgreSQL (NeonDB/Supabase): provider  = "sqlite"
//   MySQL (Aiven):                provider  = "sqlite"
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Ganti sesuai provider di .env:
  //   "postgresql" → NeonDB / Supabase
  //   "mysql"      → Aiven MySQL
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  // directUrl dipakai untuk NeonDB + connection pooling (pgbouncer)
  // Untuk MySQL/Supabase non-pooled, bisa dikosongkan atau sama dengan DATABASE_URL
  directUrl = env("DATABASE_DIRECT_URL")
}

// =====================================================
// CORE: Multi-Tenant & Authentication
// =====================================================

model Tenant {
  id              String    @id @default(cuid())
  name            String    // Nama Yayasan / MTs
  slug            String    @unique // URL-friendly identifier
  code            String    @unique // Kode sekolah (NPSN/NISM)
  address         String?
  city            String    @default("Malang")
  province        String    @default("Jawa Timur")
  phone           String?
  email           String?
  logo            String?   // Path to logo image
  npsn            String?   // Nomor Pokok Sekolah Nasional (DAPODIK)
  nism            String?   // Nomor Induk Sekolah Madrasah (EMIS)
  isActive        Boolean   @default(true)
  subscriptionEnd DateTime? // Tanggal berlangganan berakhir
  maxStudents     Int       @default(500)
  currentStudents Int       @default(0)

  // Relations
  users           User[]
  students        Student[]
  academicYears   AcademicYear[]
  classes         Classroom[]
  subjects        Subject[]
  attendances     Attendance[]
  payments        Payment[]
  announcements   Announcement[]
  grades          Grade[]
  gradeDetails    GradeDetail[]
  whatsappConfigs WhatsappConfig[]
  schedules       Schedule[]
  violations      StudentViolation[]
  achievements    StudentAchievement[]
  tahfizRecords   TahfizRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  email         String
  password      String   // Hashed password
  phone         String?
  role          UserRole @default(GURU)
  avatar        String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?

  // DAPODIK/EMIS integration
  nuptk         String?  // Nomor Unik Pendidik dan Tenaga Kependidikan
  nip           String?  // Nomor Induk Pegawai

  // Relations
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  gradeEntries  Grade[]              @relation("GradeTeacher")
  attendanceMarks Attendance[]       @relation("AttendanceRecorder")
  waliKelasOf   Classroom[]         @relation("WaliKelas")
  subjects      Subject[]           @relation("SubjectTeacher")
  scheduleSlots Schedule[]          @relation("ScheduleTeacher")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN   // Platform admin
  KEPALA_MADRASAH // Head of school
  TATA_USAHA    // Administration staff
  GURU          // Teacher
  WALI_KELAS    // Homeroom teacher
  OPERATOR      // Data entry operator

  @@map("user_roles")
}

// =====================================================
// ACADEMIC: Tahun Ajaran, Kelas, Mata Pelajaran
// =====================================================

model AcademicYear {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // "2025/2026"
  semester    Int      @default(1) // 1 = Ganjil, 2 = Genap
  isActive    Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  classes     Classroom[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name, semester])
  @@map("academic_years")
}

model Classroom {
  id              String   @id @default(cuid())
  tenantId        String
  academicYearId  String
  name            String   // "VII-A", "VIII-B", "IX-C"
  level           Int      // 7, 8, 9 (kelas 7/8/9)
  capacity        Int      @default(36)
  waliKelasId     String?  // Homeroom teacher user ID

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  waliKelas       User?        @relation("WaliKelas", fields: [waliKelasId], references: [id])
  students        Student[]
  subjects        Subject[]
  schedules        Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, academicYearId, name])
  @@map("classrooms")
}

model Subject {
  id              String   @id @default(cuid())
  tenantId        String
  classroomId     String
  name            String   // "Matematika", "Bahasa Arab", "Al-Quran"
  code            String?  // Subject code
  hoursPerWeek    Int      @default(2) // Jam per minggu
  teacherId       String?  // Guru pengampu
  category        SubjectCategory @default(UMUM)

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  classroom       Classroom @relation(fields: [classroomId], references: [id])
  teacher         User?     @relation("SubjectTeacher", fields: [teacherId], references: [id])
  grades          Grade[]
  gradeDetails    GradeDetail[]
  schedules        Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subjects")
}

enum SubjectCategory {
  UMUM         // Umum (Matematika, IPA, IPS, dll)
  AGAMA_ISLAM  // Pendidikan Agama Islam
  ARAB         // Bahasa Arab
  QURAN        // Al-Quran & Hadits
  MUATAN_LOCAL // Muatan Lokal (Bahasa Jawa, dll)
  EKSTRA       // Ekstrakurikuler

  @@map("subject_categories")
}

// =====================================================
// STUDENT DATA
// =====================================================

model Student {
  id              String        @id @default(cuid())
  tenantId        String
  classroomId     String?
  nis             String        // Nomor Induk Siswa
  nisn            String?       // Nomor Induk Siswa Nasional (DAPODIK)
  name            String
  gender          Gender        @default(L)
  birthPlace      String?
  birthDate       DateTime?
  address         String?
  photo           String?       // Path to student photo

  // Orang Tua / Wali
  fatherName      String?
  fatherPhone     String?
  motherName      String?
  motherPhone     String?
  guardianName    String?       // Wali (jika bukan orang tua)
  guardianPhone   String?
  parentEmail     String?       // Email untuk login Parent Portal

  // DAPODIK / EMIS
  nik             String?       // Nomor Induk Kependudukan
  religion        String?       @default("Islam")
  enrollmentDate  DateTime?     // Tanggal masuk

  isActive        Boolean       @default(true)

  // Login Siswa
  studentPassword String?       // Password untuk login Student Portal

  // Relations
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  classroom       Classroom?   @relation(fields: [classroomId], references: [id])
  attendances     Attendance[]
  grades          Grade[]
  gradeDetails    GradeDetail[]
  payments        Payment[]
  violations      StudentViolation[]
  achievements    StudentAchievement[]
  tahfizRecords   TahfizRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, nis])
  @@map("students")
}

enum Gender {
  L // Laki-laki
  P // Perempuan

  @@map("genders")
}

// =====================================================
// PRESENSI (Attendance)
// =====================================================

model Attendance {
  id          String          @id @default(cuid())
  tenantId    String
  studentId   String
  date        DateTime        // Tanggal presensi
  status      AttendanceStatus @default(HADIR)
  timeIn      DateTime?       // Jam masuk
  timeOut     DateTime?       // Jam pulang
  note        String?         // Keterangan (sakit perlu surat, dll)
  recordedBy  String?         // User ID yang input

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id])
  recorder    User?           @relation("AttendanceRecorder", fields: [recordedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId, date])
  @@map("attendances")
}

enum AttendanceStatus {
  HADIR   // Hadir
  SAKIT   // Sakit
  IZIN    // Izin
  ALPHA   // Tanpa keterangan

  @@map("attendance_statuses")
}

// =====================================================
// NILAI (Grades)
// =====================================================

model Grade {
  id          String      @id @default(cuid())
  tenantId    String
  studentId   String
  subjectId   String
  teacherId   String?     // Guru yang input
  type        GradeType   @default(PENGETAHUAN)
  score       Float       @default(0)
  description String?     // Deskripsi capaian kompetensi

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  student     Student     @relation(fields: [studentId], references: [id])
  subject     Subject     @relation(fields: [subjectId], references: [id])
  teacher     User?       @relation("GradeTeacher", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId, subjectId, type])
  @@map("grades")
}

enum GradeType {
  PENGETAHUAN   // Nilai Pengetahuan
  KETERAMPILAN  // Nilai Keterampilan
  SIKAP         // Nilai Sikap
  UTS           // Ujian Tengah Semester
  UAS           // Ujian Akhir Semester
  PAS           // Penilaian Akhir Semester
  RAPOR         // Nilai Rapor

  @@map("grade_types")
}

model GradeDetail {
  id          String              @id @default(cuid())
  tenantId    String
  studentId   String
  subjectId   String
  category    GradeDetailCategory @default(TUGAS)
  title       String              // "Tugas 1", "Kuis 2", "UAS Semester Genap", dll.
  score       Float               @default(0)
  weight      Float               @default(1)   // Bobot/berat penilaian
  date        DateTime?           // Tanggal penilaian
  note        String?             // Keterangan

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  student     Student             @relation(fields: [studentId], references: [id])
  subject     Subject             @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("grade_details")
}

enum GradeDetailCategory {
  TUGAS     // Tugas / PR
  HARIAN    // Ulangan Harian
  UTS       // Ujian Tengah Semester
  UAS       // Ujian Akhir Semester
  AKHIR     // Nilai Akhir (komposit)

  @@map("grade_detail_categories")
}

// =====================================================
// KEUANGAN (Payments/SPP)
// =====================================================

model Payment {
  id              String        @id @default(cuid())
  tenantId        String
  studentId       String
  type            PaymentType   @default(SPP)
  amount          Int           // Dalam Rupiah (tanpa desimal)
  month           Int?          // Bulan (1-12) untuk SPP
  year            Int?          // Tahun
  status          PaymentStatus @default(BELUM_BAYAR)
  paidAt          DateTime?     // Tanggal bayar
  paymentMethod   String?       // transfer, cash, midtrans
  transactionRef  String?       // Referensi transaksi Midtrans/Xendit
  note            String?
  dueDate         DateTime?     // Tanggal jatuh tempo

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

enum PaymentType {
  SPP           // SPP Bulanan
  DAFTAR_ULANG  // Daftar Ulang
  SERAGAM       // Seragam
  BUKU          // Buku Paket
  KEGIATAN      // Biaya Kegiatan
  LAIN_LAIN     // Lain-lain

  @@map("payment_types")
}

enum PaymentStatus {
  BELUM_BAYAR  // Belum dibayar
  MENUNGGU     // Menunggu verifikasi
  LUNAS        // Sudah lunas
  SEBAGIAN     // Bayar sebagian

  @@map("payment_statuses")
}

// =====================================================
// PENGUMUMAN (Announcements)
// =====================================================

model Announcement {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  content     String
  category    String   @default("umum") // umum, akademik, keagamaan, keuangan
  isPinned    Boolean  @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// =====================================================
// JADWAL PELAJARAN (Schedule)
// =====================================================

model Schedule {
  id              String   @id @default(cuid())
  tenantId        String
  classroomId     String
  subjectId       String
  dayOfWeek       Int      // 1=Senin, 2=Selasa, ..., 6=Sabtu, 0=Minggu
  startPeriod     Int      // Jam ke- (1-10)
  endPeriod       Int      // Jam ke- (1-10)
  teacherId       String?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  classroom       Classroom @relation(fields: [classroomId], references: [id])
  subject         Subject   @relation(fields: [subjectId], references: [id])
  teacher         User?     @relation("ScheduleTeacher", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

// =====================================================
// KESISWAAN: Pelanggaran (Violations)
// =====================================================

model StudentViolation {
  id          String   @id @default(cuid())
  tenantId    String
  studentId   String
  date        DateTime
  category    String   // ringan, sedang, berat
  description String
  points      Int      @default(0)  // Poin pelanggaran (negatif)
  action      String?  // Tindakan / sanksi
  recordedBy  String?  // User ID

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_violations")
}

// =====================================================
// KESISWAAN: Prestasi (Achievements)
// =====================================================

model StudentAchievement {
  id          String   @id @default(cuid())
  tenantId    String
  studentId   String
  date        DateTime
  title       String
  category    String   // akademik, non-akademik, keagamaan, olahraga, seni
  level       String   // kelas, sekolah, kecamatan, kota, provinsi, nasional, internasional
  ranking     String?  // Juara 1, 2, 3, Peserta
  description String?
  certificate String? // Path to certificate

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_achievements")
}

// =====================================================
// TAHFIZ: Monitoring Hafalan
// =====================================================

model TahfizRecord {
  id              String   @id @default(cuid())
  tenantId        String
  studentId       String
  date            DateTime
  surah           String   // Nama surah
  ayahStart       Int      // Ayat mulai
  ayahEnd         Int      // Ayat selesai
  type            String   // ziyadah (tambahan baru), murajaah (pengulangan)
  score           Float    @default(0) // Nilai 0-100
  fluency         String?  // lancar, cukup, kurang
  note            String?
  recordedBy      String?  // User ID guru tahfiz

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tahfiz_records")
}

// =====================================================
// WHATSAPP CONFIG (Self-hosted Baileys)
// =====================================================

model WhatsappConfig {
  id              String   @id @default(cuid())
  tenantId        String
  sessionName     String   // Nama session Baileys
  sessionId       String?  // Session data (encrypted)
  qrCode          String?  // QR code terakhir (base64)
  isConnected     Boolean  @default(false)
  phoneNumber     String?  // Nomor WA sekolah
  lastConnectedAt DateTime?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whatsapp_configs")
}
