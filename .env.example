# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Options: "sqlite" | "postgresql" | "mysql"
#
# Development  : sqlite  → file:../db/custom.db
# Railway/Render : postgresql → Neon (recommended) atau Render PostgreSQL
# PlanetScale  : mysql   → serverless MySQL
DATABASE_PROVIDER="sqlite"

# SQLite (development lokal)
DATABASE_URL="file:../db/custom.db"

# PostgreSQL — Neon (recommended untuk Railway & Render — serverless, gratis, PWA-friendly)
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/dbname?sslmode=require"

# PostgreSQL — Neon direct (tanpa pooler, untuk prisma migrate/db push)
# DATABASE_DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# PostgreSQL — Render internal database
# DATABASE_URL="postgresql://user:password@dpg-xxx.render.com/dbname"

# PostgreSQL — Railway internal database (gunakan variable reference di dashboard)
# DATABASE_URL="${{Postgres.DATABASE_URL}}"

# MySQL — PlanetScale (serverless MySQL, edge-ready)
# DATABASE_URL="mysql://user:password@aws.connect.psdb.cloud/dbname?sslaccept=strict"

# Required untuk NeonDB pooled connection (kosongkan jika pakai provider lain)
DATABASE_DIRECT_URL=""

# ==============================================================================
# CLOUD STORAGE CONFIGURATION
# ==============================================================================
# Options: "imagekit" | "cloudinary"
# ImageKit: free 20GB bandwidth/bulan — cocok untuk foto siswa & dokumen
# Cloudinary: free 25 credits/bulan
STORAGE_PROVIDER="imagekit"

# ImageKit Credentials (required if STORAGE_PROVIDER="imagekit")
IMAGEKIT_PUBLIC_KEY="your_imagekit_public_key"
IMAGEKIT_PRIVATE_KEY="your_imagekit_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"

# Cloudinary Credentials (required if STORAGE_PROVIDER="cloudinary")
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# ==============================================================================
# EXTERNAL INTEGRATION: WHATSAPP GATEWAY
# ==============================================================================
# Endpoint API WhatsApp Gateway Node.js (e.g. http://localhost:8000 or Railway URL)
WA_SERVICE_URL="http://localhost:8000"
WA_SERVICE_SECRET="generate_a_very_long_secure_random_token"

# ==============================================================================
# RUNTIME (set otomatis oleh Railway/Render, tidak perlu diisi manual)
# ==============================================================================
# PORT=3000
# NODE_ENV=production
