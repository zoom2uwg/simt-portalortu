{
    "name": "simt/mts",
    "type": "project",
    "description": "Sistem Informasi Manajemen Terpadu Madrasah Tsanawiyah - Integrated School Management System",
    "keywords": ["laravel", "madrasah", "school-management", "mt", "simt"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "nwidart/laravel-modules": "^11.0",
        "spatie/laravel-permission": "^6.0",
        "barryvdh/laravel-dompdf": "^2.0",
        "maatwebsite/excel": "^3.1",
        "laravel/ui": "^4.0",
        "guzzlehttp/guzzle": "^7.8",
        "intervention/image": "^3.0",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.0",
        "predis/predis": "^2.2",
        "laravel/horizon": "^5.0",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-backup": "^8.6",
        "spatie/laravel-medialibrary": "^11.0",
        "rappasoft/laravel-livewire-tables": "^3.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan module:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
